# .env.example
#
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.
#
# In Cloud Run, these values are stored in Secret Manager and injected
# automatically as environment variables when the job runs.
# Variable names must match exactly between .env and Secret Manager.

# GCP project where your BigQuery datasets and GCS buckets live.
GCP_PROJECT_ID=your-project-id

# GCP region for Cloud Run and other resources.
GCP_REGION=europe-west2

# BigQuery dataset for this pipeline's output tables.
BQ_DATASET=your_dataset_name

# GCS bucket used for data inputs/outputs (not the code bucket).
GCS_DATA_BUCKET=your-data-bucket-name

# Optional: path to a service account key file for local auth.
# Not needed if you have already run: gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
