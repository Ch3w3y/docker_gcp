# .env.example
#
# Required environment variables for the AMR surveillance pipeline.
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
#
# In Cloud Run: these variables are loaded from Secret Manager.
# Locally:      docker compose loads this file automatically.

# ---- GCP Configuration ----

# Your GCP project ID (find it in the GCP Console or ask your platform team)
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery dataset containing the AMR isolates source table
BQ_DATASET=your_dataset_name

# GCS bucket for output files
GCS_DATA_BUCKET=your-bucket-name

# ---- Table Names (optional — defaults shown) ----

# Source table containing raw isolate records
# Default: amr_isolates
BQ_SOURCE_TABLE=amr_isolates

# Output table for monthly resistance rates
# Default: amr_monthly_rates
BQ_OUTPUT_TABLE=amr_monthly_rates
